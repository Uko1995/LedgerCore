# =============================================================================
# LedgerCore - Environment Configuration
# =============================================================================

# Application Server Port
SERVER_PORT=8081

# Spring Profile (default for Docker deployment)
SPRING_PROFILES_ACTIVE=docker

# Database credentials (SQL Server)
JDBC_DATABASE_URL=jdbc:sqlserver://localhost:1433;databaseName=ledger_mock;encrypt=false;trustServerCertificate=true
JDBC_DATABASE_USERNAME=sa
JDBC_DATABASE_PASSWORD=change-me

# Docker SQL Server SA password (must match JDBC_DATABASE_PASSWORD above)
MSSQL_SA_PASSWORD=change-me

# Logging Level
LOGGING_LEVEL=INFO
